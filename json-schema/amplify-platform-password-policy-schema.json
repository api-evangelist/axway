{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://api-evangelist.com/schemas/axway/amplify-platform-password-policy-schema.json",
  "title": "PasswordPolicy",
  "description": "Password policy",
  "type": "object",
  "properties": {
    "length": {
      "type": "integer",
      "minimum": 9,
      "maximum": 127,
      "default": 8,
      "example": 1
    },
    "max_length": {
      "type": "integer",
      "minimum": 9,
      "maximum": 127,
      "default": 128,
      "example": 1
    },
    "lower": {
      "type": "integer",
      "minimum": 1,
      "example": 1
    },
    "upper": {
      "type": "integer",
      "minimum": 1,
      "example": 1
    },
    "special": {
      "type": "integer",
      "minimum": 1,
      "example": 1
    },
    "digit": {
      "type": "integer",
      "minimum": 1,
      "example": 1
    },
    "lockout": {
      "type": "integer",
      "minimum": 1,
      "maximum": 4,
      "default": 5,
      "example": 1
    },
    "renewal": {
      "type": "integer",
      "minimum": 1,
      "example": 1
    },
    "history": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10,
      "example": 1
    }
  }
}